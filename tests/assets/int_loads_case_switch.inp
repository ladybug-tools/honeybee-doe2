   TYPE = CONDITIONED
   DESIGN-COOL-T =
{switch(#LR("SPACE", "C-ACTIVITY-DESC"))
case "npln": 75.2
case "m5m2": 75.2
case "mthr": 75.2
default: no_default
endswitch}
..

SET-DEFAULT FOR ZONE
   TYPE = CONDITIONED
   HEAT-TEMP-SCH =
{switch(#LR("SPACE", "C-ACTIVITY-DESC"))
case "npln": #SI("NECBAThrmstt StpntHtng", "ZONE", "HEAT-TEMP-SCH")
case "m5m2": #SI("NECBKThrmstt StpntHtng", "ZONE", "HEAT-TEMP-SCH")
case "mthr": #SI("NECBAThrmstt StpntHtng", "ZONE", "HEAT-TEMP-SCH")
default: no_default
endswitch}
..

SET-DEFAULT FOR ZONE
   TYPE = CONDITIONED
   COOL-TEMP-SCH =
{switch(#LR("SPACE", "C-ACTIVITY-DESC"))
case "npln": #SI("NECBAThrmstt StpntClng", "ZONE", "COOL-TEMP-SCH")
case "m5m2": #SI("NECBKThrmstt StpntClng", "ZONE", "COOL-TEMP-SCH")
case "mthr": #SI("NECBAThrmstt StpntClng", "ZONE", "COOL-TEMP-SCH")
default: no_default
endswitch}
..

SET-DEFAULT FOR ZONE
   TYPE = CONDITIONED
   OA-FLOW/PER =
{switch(#LR("SPACE", "C-ACTIVITY-DESC"))
case "npln": 20.0
case "mthr": 50.0
default: no_default
endswitch}
..

SET-DEFAULT FOR ZONE
   TYPE = CONDITIONED
   OA-FLOW/AREA =
{switch(#LR("SPACE", "C-ACTIVITY-DESC"))
case "m5m2": 0.15
default: no_default
endswitch}
..

"0_Sys" = SYSTEM
   TYPE                     = SUM
   HEAT-SOURCE              = NONE
   SYSTEM-REPORTS           = NO
   ..

"Washroom_Zn" = ZONE
   TYPE                     = UNCONDITIONED
   SIZING-OPTION            = ADJUST-LOADS
   SPACE                    = "Washroom"
   ..

"Office_Zn" = ZONE
   TYPE                     = UNCONDITIONED
   SIZING-OPTION            = ADJUST-LOADS
   SPACE                    = "Office"
   ..

"Storage_Zn" = ZONE
   TYPE                     = UNCONDITIONED
   SIZING-OPTION            = ADJUST-LOADS
   SPACE                    = "Storage"
   ..

